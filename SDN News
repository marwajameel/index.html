<!DOCTYPE html>
<html lang="ur">
<head>
    <meta charset="UTF-8">
    <title>SDN News - Wallet Batch Transaction</title>
    <style>
        .btn-style {
            background-color: #007bff;
            color: white;
            padding: 15px 25px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 18px;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        #status { margin-top: 20px; font-family: Arial, sans-serif; font-weight: bold; }
    </style>
</head>
<body style="text-align: center; direction: rtl; padding-top: 50px; background-color: #f4f4f4;">

    <h2 style="color: #333;">والٹ بیچ ٹرانزیکشن سسٹم (SDN News)</h2>
    <p>صارف: <strong>Jamilahmed.base.eth</strong></p>
    
    <button id="sendBatchBtn" class="btn-style">ٹرانزیکشن بیچ شروع کریں</button>
    
    <div id="status">اسٹیٹس: والٹ کنیکٹ ہونے کا انتظار ہے...</div>

    <script>
        const btn = document.getElementById('sendBatchBtn');
        const statusDiv = document.getElementById('status');
        
        // آپ کا بیس ایڈریس / ENS
        const userAddress = "Jamilahmed.base.eth";

        btn.addEventListener('click', async () => {
            if (typeof window.ethereum !== 'undefined') {
                try {
                    // والٹ سے رابطہ کرنا
                    await window.ethereum.request({ method: 'eth_requestAccounts' });
                    statusDiv.innerHTML = "کنیکٹڈ: <span style='color:green;'>" + userAddress + "</span>";

                    // ٹرانزیکشن بیچ (Batch) بھیجنا
                    const callsId = await window.ethereum.request({
                        method: 'wallet_sendCalls',
                        params: [{
                            version: '1.0',
                            chainId: '0x2105', // Base Mainnet ID
                            from: userAddress,
                            calls: [
                                { to: '0x...', value: '0x0', data: '0x' }, // پہلی کال
                                { to: '0x...', value: '0x0', data: '0x' }  // دوسری کال
                            ]
                        }]
                    });

                    statusDiv.innerText = "بیچ پروسیس ہو رہا ہے۔ آئی ڈی: " + callsId;
                    checkStatus(callsId);

                } catch (error) {
                    statusDiv.innerText = "خرابی: " + error.message;
                    console.error(error);
                }
            } else {
                alert("براہ کرم کوئی کرپٹو والٹ (جیسے Coinbase یا MetaMask) انسٹال کریں۔");
            }
        });

        async function checkStatus(callsId) {
            try {
                const status = await window.ethereum.request({
                    method: 'wallet_getCallsStatus',
                    params: [callsId]
                });

                if (status.status === 200) {
                    statusDiv.innerHTML = "<span style='color:green;'>کامیابی! تمام ٹرانزیکشنز مکمل ہو گئیں۔</span>";
                } else if (status.status === 100) {
                    statusDiv.innerText = "ٹرانزیکشن جاری ہے... براہ کرم انتظار کریں۔";
                    setTimeout(() => checkStatus(callsId), 3000);
                } else {
                    statusDiv.innerText = "ٹرانزیکشن میں کوئی مسئلہ پیش آگیا ہے۔";
                }
            } catch (error) {
                console.error("اسٹیٹس ایرر:", error);
            }
        }
    </script>

</body>
</html>
